{
  "name": "betterdb-memory",
  "version": "0.1.2",
  "description": "Persistent semantic memory for Claude Code — powered by Valkey",
  "author": {
    "name": "BetterDB Inc.",
    "email": "hello@betterdb.com"
  },
  "homepage": "https://github.com/BetterDB-inc/memory",
  "repository": "https://github.com/BetterDB-inc/memory",
  "license": "MIT",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hooks/session-start.ts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hooks/pre-tool.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hooks/post-tool.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/src/hooks/session-end.ts"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "betterdb-memory": {
      "command": "bun",
      "args": ["run", "${CLAUDE_PLUGIN_ROOT}/src/mcp/server.ts"]
    }
  }
}
